{
  "manifest_version": 2,
  "name": "__MSG_extensionName__",
  "version": "0.4.0",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "permissions": [
    "storage",
    "tabs",
    "clipboardWrite"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
"js": [
          "Readability.js",
          "text_limiter.js",
          "i18n.js",
          "content_script.js"
        ]
    }
  ],
  "browser_action": {
    "default_title": "__MSG_browserActionTitle__",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "options_ui": {
    "page": "options.html",
    "browser_style": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "pagenexus@paulista.systems",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}